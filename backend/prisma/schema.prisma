generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum TypeCommerce {
  Electronique
  Vulcanisateur
  MecaniqueGarage
  AccessoireAuto
}

enum StatutPartenaire {
  actif
  inactif
}

enum StatutIncendie {
  en_cours
  complet
  expire
}

enum WaveStatut {
  en_attente
  confirme
  echoue
}

enum StatutDossier {
  paye_formulaire_attente
  complet
}

enum TypeAction {
  creation
  modification
  suppression
  export
  connexion
  relance
}

enum StatutDemande {
  en_attente
  validee
  rejetee
}

enum Branche {
  INCENDIE_ACCIDENT
  RELAX
  IMF
}

enum RoleImf {
  AGENT
  RESPONSABLE_AGENCE
  RESPONSABLE_ZONE
}

enum TypePaiement {
  FACTURE
  WAVE
}

enum StatutSouscription {
  en_cours
  complet
  expire
}

enum CycleFacturation {
  hebdo5semaines
  mensuel
  annuel
}

enum StatutAbonnement {
  actif
  suspendu
  expire
  resilie
}

enum StatutEcheance {
  en_attente
  paye
  echoue
}

enum TypeDocument {
  CNI
  Permis
}

enum StatutValidationDocument {
  en_attente
  valide
  rejete
}

enum StatutCarte {
  generee
  envoyee
  activee
}

model Admin {
  id           String            @id @default(uuid())
  nom          String
  email        String            @unique
  passwordHash String
  role         Role              @default(ADMIN)
  // Branches auxquelles l'admin a accès (Assurances Incendie/Accident et/ou Relax).
  // Défaut = les deux, pour ne pas retirer l'accès aux comptes déjà existants
  // au moment de l'introduction de ce champ. Un SUPER_ADMIN a toujours accès
  // aux deux branches, quel que soit le contenu de cette colonne (voir auth.ts).
  branches     Branche[]         @default([INCENDIE_ACCIDENT, RELAX])
  createdAt    DateTime          @default(now())
  journal      JournalActivite[]
}

model Partenaire {
  id                  String                 @id @default(uuid())
  nomCommerce         String
  nomResponsable      String
  telephone           String
  // Optionnels pour la branche Relax (RelaxMoto/RelaxAuto), où seuls le nom
  // et prénoms du partenaire comptent — toujours requis pour Incendie/Accident
  // (validation faite côté formulaire admin).
  localisation        String?
  typeCommerce        TypeCommerce?
  produitIncendie     Boolean                @default(false)
  produitAccident     Boolean                @default(false)
  qrIncendie1000Token String?                @unique
  qrIncendie2000Token String?                @unique
  qrAccidentToken     String?                @unique
  statut              StatutPartenaire       @default(actif)
  email               String?                @unique
  passwordHash        String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  incendie            SouscriptionIncendie[]
  accident            SouscriptionAccident[]
  demandes            DemandeCommission[]
  notifications       Notification[]

  // --- Modèle générique (en cours de migration, cf. Produit/QrCode/Souscription) ---
  branche          Branche?
  qrCodes          QrCode[]
  souscriptionsGen Souscription[]
}

model SouscriptionIncendie {
  id                  String         @id @default(uuid())
  partenaireId        String
  partenaire          Partenaire     @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  telephone           String
  nom                 String?
  prenom              String?
  email               String?
  refFacture          String?        @map("numeroFacture")
  commune             String?
  quartier            String?
  numeroMaison        String?
  pieceIdentiteUrl    String?
  montantPrime        Int            @default(1000)
  capitalGaranti      Int            @default(250000)
  commissionCalculee  Float?
  statut              StatutIncendie @default(en_cours)
  lienFormulaireToken String?        @unique
  whatsappEnvoyeAt    DateTime?
  relanceCount        Int            @default(0)
  signature           String? // data URL PNG, capturée à la complétion du formulaire
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model SouscriptionAccident {
  id                   String        @id @default(uuid())
  partenaireId         String
  partenaire           Partenaire    @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  telephone            String
  nom                  String
  prenom               String
  dateNaissance        DateTime?
  montantPrime         Int
  capitalGaranti       Int           @default(100000)
  commissionCalculee   Float?
  waveNumero           String?
  waveTransactionId    String?
  waveStatut           WaveStatut    @default(en_attente)
  numeroPolice         String?       @unique
  dateDebut            DateTime?
  dateFin              DateTime?
  statutDossier        StatutDossier @default(paye_formulaire_attente)
  formulaireComplement Json?
  whatsappEnvoyeAt     DateTime?
  relanceCount         Int           @default(0)
  signature            String? // data URL PNG, capturée avant le paiement Wave
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model JournalActivite {
  id          String     @id @default(uuid())
  adminId     String?
  admin       Admin?     @relation(fields: [adminId], references: [id], onDelete: SetNull)
  typeAction  TypeAction
  objetType   String
  objetId     String?
  ip          String?
  valeurAvant Json?
  valeurApres Json?
  createdAt   DateTime   @default(now())
}

model DemandeCommission {
  id           String        @id @default(uuid())
  partenaireId String
  partenaire   Partenaire    @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  montant      Float
  statut       StatutDemande @default(en_attente)
  periodeDebut DateTime?
  periodeFin   DateTime?
  traiteePar   String?
  traiteeAt    DateTime?
  motifRejet   String?
  createdAt    DateTime      @default(now())
}

model Notification {
  id           String      @id @default(uuid())
  cible        String
  partenaireId String?
  partenaire   Partenaire? @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  type         String
  titre        String
  message      String
  lien         String?
  lu           Boolean     @default(false)
  createdAt    DateTime    @default(now())

  @@index([cible, partenaireId, lu])
}

model Parametre {
  id                              Int   @id @default(1)
  tauxCommissionIncendie          Float @default(0.20)
  tauxCommissionAccident          Float @default(0.15)
  tauxCommissionMensuelleIncendie Float @default(0.10)
  primeAccident                   Int   @default(2000)
  primeHtIncendie1000             Float @default(800)
  primeHtIncendie2000             Float @default(1600)
}

model TarifAccident {
  id             Int      @id @default(autoincrement())
  prime          Int      @unique
  primeHT        Float?
  fg             Float?
  taxes          Float?
  capitalGaranti Int
  commission     Float
  createdAt      DateTime @default(now())
}

model TarifIncendie {
  id             Int      @id @default(autoincrement())
  prime          Int      @unique
  primeHT        Float?
  fg             Float?
  taxes          Float?
  capitalGaranti Int
  commission     Float
  createdAt      DateTime @default(now())
}

// =====================================================================
// Modèle générique Produit / Branche — cible de la migration en cours.
// Coexiste avec les modèles historiques ci-dessus le temps de la bascule
// (voir backend/scripts/migrate-produits.ts). Incendie et Accident restent
// la source de vérité tant que les routes ne sont pas migrées ; RelaxMoto
// et RelaxAuto sont créés directement sur ce modèle générique.
// =====================================================================

model Produit {
  id            String         @id @default(uuid())
  code          String         @unique // "incendie" | "accident" | "relaxmoto" | "relaxauto"
  libelle       String
  branche       Branche
  typePaiement  TypePaiement
  couleurQr     String         @default("#004b9c")
  actif         Boolean        @default(true)
  ordre         Int            @default(0)
  createdAt     DateTime       @default(now())
  tarifs        TarifProduit[]
  qrCodes       QrCode[]
  souscriptions Souscription[]
}

model TarifProduit {
  id                      Int      @id @default(autoincrement())
  produitId               String
  produit                 Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
  libelleVariante         String? // ex: "1000"/"2000" pour incendie, null sinon
  prime                   Int
  primeHT                 Float?
  fg                      Float?
  taxes                   Float?
  capitalGaranti          Int
  commission              Float
  tauxCommissionMensuelle Float?
  createdAt               DateTime @default(now())

  @@unique([produitId, prime])
}

model QrCode {
  id              String     @id @default(uuid())
  partenaireId    String
  partenaire      Partenaire @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  produitId       String
  produit         Produit    @relation(fields: [produitId], references: [id])
  libelleVariante String? // distingue plusieurs QR pour un même produit (ex incendie 1000/2000)
  token           String     @unique
  actif           Boolean    @default(true)
  createdAt       DateTime   @default(now())

  @@unique([partenaireId, produitId, libelleVariante])
}

model Souscription {
  id                   String             @id @default(uuid())
  produitId            String
  produit              Produit            @relation(fields: [produitId], references: [id])
  partenaireId         String
  partenaire           Partenaire         @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  telephone            String
  nom                  String?
  prenom               String?
  email                String?
  dateNaissance        DateTime?
  commune              String?
  quartier             String?
  numeroMaison         String?
  pieceIdentiteUrl     String?
  montantPrime         Int
  capitalGaranti       Int
  commissionCalculee   Float?
  refFacture           String? // paiement FACTURE (ex incendie)
  waveNumero           String? // paiement WAVE
  waveTransactionId    String?
  waveStatut           WaveStatut?
  numeroPolice         String?            @unique
  dateDebut            DateTime?
  dateFin              DateTime?
  statut               StatutSouscription @default(en_cours)
  lienFormulaireToken  String?            @unique
  formulaireComplement Json?
  whatsappEnvoyeAt     DateTime?
  relanceCount         Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // --- Abonnement récurrent (RelaxMoto/RelaxAuto : paiement en plusieurs échéances) ---
  cycleFacturation CycleFacturation?
  statutAbonnement StatutAbonnement?
  nombreEcheances  Int?
  paiements        Paiement[]
  documents        Document[]
  carte            Carte?
}

/**
 * Échéance d'un abonnement récurrent (RelaxMoto/RelaxAuto). `TarifProduit.prime`
 * reste la prime annuelle de référence ; le cycle choisi (hebdo5semaines/mensuel/
 * annuel) détermine seulement le nombre d'échéances et la répartition du montant.
 */
model Paiement {
  id                String         @id @default(uuid())
  souscriptionId    String
  souscription      Souscription   @relation(fields: [souscriptionId], references: [id], onDelete: Cascade)
  numeroEcheance    Int
  montant           Int
  statut            StatutEcheance @default(en_attente)
  dateEcheance      DateTime
  datePaiement      DateTime?
  waveTransactionId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([souscriptionId, numeroEcheance])
}

model Document {
  id               String                   @id @default(uuid())
  souscriptionId   String
  souscription     Souscription             @relation(fields: [souscriptionId], references: [id], onDelete: Cascade)
  type             TypeDocument
  url              String
  statutValidation StatutValidationDocument @default(en_attente)
  motifRejet       String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

/**
 * Carte de prise en charge — génération via NOVELIA (mode stub tant que l'API n'est pas branchée)
 */
model Carte {
  id                 String       @id @default(uuid())
  souscriptionId     String       @unique
  souscription       Souscription @relation(fields: [souscriptionId], references: [id], onDelete: Cascade)
  numero             String       @unique
  statut             StatutCarte  @default(generee)
  noveliaRef         String?
  dateGeneration     DateTime     @default(now())
  dateEnvoi          DateTime?
  dateActivation     DateTime?
  dateRenouvellement DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// --- Branche IMF : hiérarchie Zone -> Agence -> Agent (distribution par agent, pas par QR) ---

model ZoneImf {
  id        String      @id @default(uuid())
  nom       String      @unique
  createdAt DateTime    @default(now())
  agences   AgenceImf[]
  agents    AgentImf[] // rattachement direct d'un RESPONSABLE_ZONE (pas d'agence intermédiaire)
}

model AgenceImf {
  id           String     @id @default(uuid())
  nom          String
  zoneId       String
  zone         ZoneImf    @relation(fields: [zoneId], references: [id])
  telephone    String?
  localisation String?
  createdAt    DateTime   @default(now())
  agents       AgentImf[]
}

model AgentImf {
  id           String           @id @default(uuid())
  nom          String
  prenom       String
  telephone    String
  email        String           @unique
  passwordHash String
  roleImf      RoleImf          @default(AGENT)
  agenceId     String? // requis si roleImf = AGENT
  agence       AgenceImf?       @relation(fields: [agenceId], references: [id])
  zoneId       String? // requis si roleImf = RESPONSABLE_ZONE
  zone         ZoneImf?         @relation(fields: [zoneId], references: [id])
  statut        StatutPartenaire  @default(actif)
  createdAt     DateTime          @default(now())
  simulations   SimulationImf[]
  souscriptions SouscriptionImf[]
}

// --- Phase 2 : moteur de tarification IMF (SECURPRO/SECURSTOCK à formules, COUPS DURS/SECURECOLTE en catalogue fixe) ---

model BaremeSecurpro {
  id            String   @id @default(uuid())
  classe        Int      @unique // 1 à 4
  limiteCapital Int
  tauxIncendie  Float // taux décimal, ex 0.00072 pour classe 1
  updatedAt     DateTime @updatedAt
}

model BaremeSecurstock {
  id                    String   @id @default(uuid())
  classe                Int      @unique
  limiteCapital         Int
  tauxDommageElectrique Float // T1
  tauxAutreCause        Float // T2
  updatedAt             DateTime @updatedAt
}

model PalierSecurecolte {
  id                String   @id @default(uuid())
  seuil             String // "forte" | "moyenne" | "faible"
  pourcentageIndice Float // borne haute du palier (0.75 / 0.85 / 0.95)
  montantIndemnite  Int
  createdAt         DateTime @default(now())
}

model IndiceArcImf {
  id        String   @id @default(uuid())
  region    String
  annee     Int
  valeur    Float // indice WRSI observé
  reference Float // valeur de référence (médiane 5 ans)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([region, annee])
}

model SimulationImf {
  id          String           @id @default(uuid())
  agentId     String
  agent       AgentImf         @relation(fields: [agentId], references: [id])
  produitCode String // "securpro" | "securstock" | "coupsdurs" | "securecolte"
  entrees     Json
  resultat    Json
  primeTTC    Int
  createdAt   DateTime         @default(now())
  souscription SouscriptionImf?
}

// --- Phase 3 (réduite) : conversion d'une simulation en souscription ---

enum StatutSouscriptionImf {
  en_cours
  active
  annulee
}

model SouscriptionImf {
  id           String                @id @default(uuid())
  numeroPolice String                @unique
  agentId      String
  agent        AgentImf              @relation(fields: [agentId], references: [id])
  simulationId String?               @unique
  simulation   SimulationImf?        @relation(fields: [simulationId], references: [id])
  produitCode  String
  nom          String
  prenom       String
  telephone    String
  email        String?
  entrees      Json
  resultat     Json
  primeTTC     Int
  statut       StatutSouscriptionImf @default(en_cours)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}
