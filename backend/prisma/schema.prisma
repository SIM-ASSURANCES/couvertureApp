generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum TypeCommerce {
  Electronique
  Vulcanisateur
  MecaniqueGarage
  AccessoireAuto
}

enum StatutPartenaire {
  actif
  inactif
}

enum StatutIncendie {
  en_cours
  complet
  expire
}

enum WaveStatut {
  en_attente
  confirme
  echoue
}

enum StatutDossier {
  paye_formulaire_attente
  complet
}

enum TypeAction {
  creation
  modification
  suppression
  export
  connexion
  relance
}

enum StatutDemande {
  en_attente
  validee
  rejetee
}

enum Branche {
  INCENDIE_ACCIDENT
  RELAX
  IMF
}

enum RoleImf {
  AGENT
  RESPONSABLE_AGENCE
  RESPONSABLE_ZONE
  // Rattaché à une agence comme RESPONSABLE_AGENCE, mais accès restreint
  // (tableau de bord, souscriptions, contrats, finance) et seul rôle à voir
  // les commissions générées par l'agence — le responsable ne les voit pas.
  FINANCE_COMPTABLE
}

enum TypePaiement {
  FACTURE
  WAVE
}

enum StatutSouscription {
  en_cours
  complet
  expire
}

enum CycleFacturation {
  hebdo5semaines
  mensuel
  annuel
}

enum StatutAbonnement {
  actif
  suspendu
  expire
  resilie
}

enum StatutEcheance {
  en_attente
  paye
  echoue
}

enum TypeDocument {
  CNI
  Permis
}

enum StatutValidationDocument {
  en_attente
  valide
  rejete
}

enum StatutCarte {
  generee
  envoyee
  activee
}

model Admin {
  id           String            @id @default(uuid())
  nom          String
  email        String            @unique
  passwordHash String
  role         Role              @default(ADMIN)
  // Branches auxquelles l'admin a accès (Assurances Incendie/Accident et/ou Relax).
  // Défaut = les deux, pour ne pas retirer l'accès aux comptes déjà existants
  // au moment de l'introduction de ce champ. Un SUPER_ADMIN a toujours accès
  // aux deux branches, quel que soit le contenu de cette colonne (voir auth.ts).
  branches     Branche[]         @default([INCENDIE_ACCIDENT, RELAX])
  createdAt    DateTime          @default(now())
  journal      JournalActivite[]
  simulationsImf   SimulationImf[]   @relation("AdminSimulationsImf")
  souscriptionsImf SouscriptionImf[] @relation("AdminSouscriptionsImf")
  sinistresImf     SinistreImf[]     @relation("AdminSinistresImf")
  bordereauxImf    BordereauImf[]    @relation("AdminBordereauxImf")
}

model Partenaire {
  id                  String                 @id @default(uuid())
  nomCommerce         String
  nomResponsable      String
  telephone           String
  // Optionnels pour la branche Relax (RelaxMoto/RelaxAuto), où seuls le nom
  // et prénoms du partenaire comptent — toujours requis pour Incendie/Accident
  // (validation faite côté formulaire admin).
  localisation        String?
  typeCommerce        TypeCommerce?
  produitIncendie     Boolean                @default(false)
  produitAccident     Boolean                @default(false)
  qrIncendie1000Token String?                @unique
  qrIncendie2000Token String?                @unique
  qrAccidentToken     String?                @unique
  statut              StatutPartenaire       @default(actif)
  email               String?                @unique
  passwordHash        String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  incendie            SouscriptionIncendie[]
  accident            SouscriptionAccident[]
  demandes            DemandeCommission[]
  notifications       Notification[]

  // --- Modèle générique (en cours de migration, cf. Produit/QrCode/Souscription) ---
  branche          Branche?
  qrCodes          QrCode[]
  souscriptionsGen Souscription[]
}

model SouscriptionIncendie {
  id                  String         @id @default(uuid())
  partenaireId        String
  partenaire          Partenaire     @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  telephone           String
  nom                 String?
  prenom              String?
  email               String?
  refFacture          String?        @map("numeroFacture")
  commune             String?
  quartier            String?
  numeroMaison        String?
  pieceIdentiteUrl    String?
  montantPrime        Int            @default(1000)
  capitalGaranti      Int            @default(250000)
  commissionCalculee  Float?
  statut              StatutIncendie @default(en_cours)
  lienFormulaireToken String?        @unique
  whatsappEnvoyeAt    DateTime?
  relanceCount        Int            @default(0)
  signature           String? // data URL PNG, capturée à la complétion du formulaire
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model SouscriptionAccident {
  id                   String        @id @default(uuid())
  partenaireId         String
  partenaire           Partenaire    @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  telephone            String
  nom                  String
  prenom               String
  dateNaissance        DateTime?
  montantPrime         Int
  capitalGaranti       Int           @default(100000)
  commissionCalculee   Float?
  waveNumero           String?
  waveTransactionId    String?
  waveStatut           WaveStatut    @default(en_attente)
  numeroPolice         String?       @unique
  dateDebut            DateTime?
  dateFin              DateTime?
  statutDossier        StatutDossier @default(paye_formulaire_attente)
  formulaireComplement Json?
  whatsappEnvoyeAt     DateTime?
  relanceCount         Int           @default(0)
  signature            String? // data URL PNG, capturée avant le paiement Wave
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model JournalActivite {
  id          String     @id @default(uuid())
  adminId     String?
  admin       Admin?     @relation(fields: [adminId], references: [id], onDelete: SetNull)
  typeAction  TypeAction
  objetType   String
  objetId     String?
  ip          String?
  valeurAvant Json?
  valeurApres Json?
  createdAt   DateTime   @default(now())
}

model DemandeCommission {
  id           String        @id @default(uuid())
  partenaireId String
  partenaire   Partenaire    @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  montant      Float
  statut       StatutDemande @default(en_attente)
  periodeDebut DateTime?
  periodeFin   DateTime?
  traiteePar   String?
  traiteeAt    DateTime?
  motifRejet   String?
  createdAt    DateTime      @default(now())
}

model Notification {
  id           String      @id @default(uuid())
  cible        String
  partenaireId String?
  partenaire   Partenaire? @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  // Branche concernée (notifications admin uniquement) : permet à chaque
  // admin de ne voir que les notifications de ses branches. Nullable pour ne
  // jamais masquer les notifications déjà existantes avant l'introduction de
  // ce champ, ni une éventuelle notification transverse future.
  branche      Branche?
  type         String
  titre        String
  message      String
  lien         String?
  lu           Boolean     @default(false)
  createdAt    DateTime    @default(now())

  @@index([cible, partenaireId, lu])
}

model Parametre {
  id                              Int   @id @default(1)
  tauxCommissionIncendie          Float @default(0.20)
  tauxCommissionAccident          Float @default(0.15)
  tauxCommissionMensuelleIncendie Float @default(0.10)
  primeAccident                   Int   @default(2000)
  primeHtIncendie1000             Float @default(800)
  primeHtIncendie2000             Float @default(1600)
}

model TarifAccident {
  id             Int      @id @default(autoincrement())
  prime          Int      @unique
  primeHT        Float?
  fg             Float?
  taxes          Float?
  capitalGaranti Int
  commission     Float
  createdAt      DateTime @default(now())
}

model TarifIncendie {
  id             Int      @id @default(autoincrement())
  prime          Int      @unique
  primeHT        Float?
  fg             Float?
  taxes          Float?
  capitalGaranti Int
  commission     Float
  createdAt      DateTime @default(now())
}

// =====================================================================
// Modèle générique Produit / Branche — cible de la migration en cours.
// Coexiste avec les modèles historiques ci-dessus le temps de la bascule
// (voir backend/scripts/migrate-produits.ts). Incendie et Accident restent
// la source de vérité tant que les routes ne sont pas migrées ; RelaxMoto
// et RelaxAuto sont créés directement sur ce modèle générique.
// =====================================================================

model Produit {
  id            String         @id @default(uuid())
  code          String         @unique // "incendie" | "accident" | "relaxmoto" | "relaxauto"
  libelle       String
  branche       Branche
  typePaiement  TypePaiement
  couleurQr     String         @default("#004b9c")
  actif         Boolean        @default(true)
  ordre         Int            @default(0)
  createdAt     DateTime       @default(now())
  tarifs        TarifProduit[]
  qrCodes       QrCode[]
  souscriptions Souscription[]
}

model TarifProduit {
  id                      Int      @id @default(autoincrement())
  produitId               String
  produit                 Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
  libelleVariante         String? // ex: "1000"/"2000" pour incendie, null sinon
  prime                   Int
  primeHT                 Float?
  fg                      Float?
  taxes                   Float?
  capitalGaranti          Int
  commission              Float
  tauxCommissionMensuelle Float?
  createdAt               DateTime @default(now())

  // Identité d'une variante = (produit, libellé), pas (produit, prime) : deux
  // garanties d'un même produit peuvent légitimement partager le même prix
  // (ex. COUPS DURS fusionné : "deces" et "plafond_500000" valent tous deux
  // 4 000 FCFA). Anciennement unique sur (produitId, prime).
  @@unique([produitId, libelleVariante])
}

model QrCode {
  id              String     @id @default(uuid())
  partenaireId    String
  partenaire      Partenaire @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  produitId       String
  produit         Produit    @relation(fields: [produitId], references: [id])
  libelleVariante String? // distingue plusieurs QR pour un même produit (ex incendie 1000/2000)
  token           String     @unique
  actif           Boolean    @default(true)
  createdAt       DateTime   @default(now())

  @@unique([partenaireId, produitId, libelleVariante])
}

model Souscription {
  id                   String             @id @default(uuid())
  produitId            String
  produit              Produit            @relation(fields: [produitId], references: [id])
  partenaireId         String
  partenaire           Partenaire         @relation(fields: [partenaireId], references: [id], onDelete: Cascade)
  telephone            String
  nom                  String?
  prenom               String?
  email                String?
  dateNaissance        DateTime?
  commune              String?
  quartier             String?
  numeroMaison         String?
  pieceIdentiteUrl     String?
  montantPrime         Int
  capitalGaranti       Int
  commissionCalculee   Float?
  refFacture           String? // paiement FACTURE (ex incendie)
  waveNumero           String? // paiement WAVE
  waveTransactionId    String?
  waveStatut           WaveStatut?
  numeroPolice         String?            @unique
  dateDebut            DateTime?
  dateFin              DateTime?
  statut               StatutSouscription @default(en_cours)
  lienFormulaireToken  String?            @unique
  formulaireComplement Json?
  whatsappEnvoyeAt     DateTime?
  relanceCount         Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // --- Abonnement récurrent (RelaxMoto/RelaxAuto : paiement en plusieurs échéances) ---
  cycleFacturation CycleFacturation?
  statutAbonnement StatutAbonnement?
  nombreEcheances  Int?
  paiements        Paiement[]
  documents        Document[]
  carte            Carte?
}

/**
 * Échéance d'un abonnement récurrent (RelaxMoto/RelaxAuto). `TarifProduit.prime`
 * reste la prime annuelle de référence ; le cycle choisi (hebdo5semaines/mensuel/
 * annuel) détermine seulement le nombre d'échéances et la répartition du montant.
 */
model Paiement {
  id                String         @id @default(uuid())
  souscriptionId    String
  souscription      Souscription   @relation(fields: [souscriptionId], references: [id], onDelete: Cascade)
  numeroEcheance    Int
  montant           Int
  statut            StatutEcheance @default(en_attente)
  dateEcheance      DateTime
  datePaiement      DateTime?
  waveTransactionId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([souscriptionId, numeroEcheance])
}

model Document {
  id               String                   @id @default(uuid())
  souscriptionId   String
  souscription     Souscription             @relation(fields: [souscriptionId], references: [id], onDelete: Cascade)
  type             TypeDocument
  url              String
  statutValidation StatutValidationDocument @default(en_attente)
  motifRejet       String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

/**
 * Carte de prise en charge — génération via NOVELIA (mode stub tant que l'API n'est pas branchée)
 */
model Carte {
  id                 String       @id @default(uuid())
  souscriptionId     String       @unique
  souscription       Souscription @relation(fields: [souscriptionId], references: [id], onDelete: Cascade)
  numero             String       @unique
  statut             StatutCarte  @default(generee)
  noveliaRef         String?
  dateGeneration     DateTime     @default(now())
  dateEnvoi          DateTime?
  dateActivation     DateTime?
  dateRenouvellement DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// --- Branche IMF : hiérarchie Zone -> Agence -> Agent (distribution par agent, pas par QR) ---

model ZoneImf {
  id        String      @id @default(uuid())
  nom       String      @unique
  createdAt DateTime    @default(now())
  agences   AgenceImf[]
  agents    AgentImf[] // rattachement direct d'un RESPONSABLE_ZONE (pas d'agence intermédiaire)
}

model AgenceImf {
  id           String     @id @default(uuid())
  nom          String
  zoneId       String
  zone         ZoneImf    @relation(fields: [zoneId], references: [id])
  telephone    String?
  localisation String?
  createdAt    DateTime   @default(now())
  agents       AgentImf[]
  bordereaux   BordereauImf[]
}

model AgentImf {
  id           String           @id @default(uuid())
  nom          String
  prenom       String
  telephone    String
  email        String           @unique
  passwordHash String
  roleImf      RoleImf          @default(AGENT)
  agenceId     String? // requis si roleImf = AGENT
  agence       AgenceImf?       @relation(fields: [agenceId], references: [id])
  zoneId       String? // requis si roleImf = RESPONSABLE_ZONE
  zone         ZoneImf?         @relation(fields: [zoneId], references: [id])
  statut        StatutPartenaire  @default(actif)
  createdAt     DateTime          @default(now())
  simulations   SimulationImf[]
  souscriptions SouscriptionImf[]
  sinistres     SinistreImf[]
}

// --- Phase 2 : moteur de tarification IMF (SECURPRO/SECURSTOCK à formules, COUPS DURS/SECURECOLTE en catalogue fixe) ---

model BaremeSecurpro {
  id            String   @id @default(uuid())
  classe        Int      @unique // 1 à 4
  limiteCapital Int
  tauxIncendie  Float // taux décimal, ex 0.00072 pour classe 1
  // Taux de commission (décimal, ex. 0.20 = 20%), appliqué sur la prime nette
  // HT de la souscription — pas sur la prime TTC.
  tauxCommission Float   @default(0.20)
  updatedAt     DateTime @updatedAt
}

model BaremeSecurstock {
  id                    String   @id @default(uuid())
  classe                Int      @unique
  limiteCapital         Int
  tauxDommageElectrique Float // T1
  tauxAutreCause        Float // T2
  // Taux de commission (décimal, ex. 0.20 = 20%), appliqué sur la prime nette HT.
  tauxCommission        Float    @default(0.20)
  updatedAt             DateTime @updatedAt
}

model PalierSecurecolte {
  id                String   @id @default(uuid())
  seuil             String // "forte" | "moyenne" | "faible"
  pourcentageIndice Float // borne haute du palier (0.75 / 0.85 / 0.95)
  montantIndemnite  Int
  createdAt         DateTime @default(now())
}

model IndiceArcImf {
  id        String   @id @default(uuid())
  region    String
  annee     Int
  valeur    Float // indice WRSI observé
  reference Float // valeur de référence (médiane 5 ans)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([region, annee])
}

model SimulationImf {
  id          String           @id @default(uuid())
  // agentId OU adminId : une simulation est faite soit par un agent du réseau,
  // soit directement par un admin (indépendant de toute zone/agence/agent).
  agentId     String?
  agent       AgentImf?        @relation(fields: [agentId], references: [id])
  adminId     String?
  admin       Admin?           @relation("AdminSimulationsImf", fields: [adminId], references: [id])
  produitCode String // "securpro" | "securstock" | "coupsdurs" | "securecolte"
  entrees     Json
  resultat    Json
  primeTTC    Int
  createdAt   DateTime         @default(now())
  souscription SouscriptionImf?
  // Identifiant généré côté client lors d'une saisie hors-ligne (PWA), utilisé
  // comme clé d'idempotence à la synchronisation : si la requête est rejouée
  // (double tap, coupure réseau après succès), la même simulation est
  // retournée au lieu d'en créer un doublon.
  offlineId   String?          @unique
}

// --- Phase 3 (réduite) : conversion d'une simulation en souscription ---

enum StatutSouscriptionImf {
  en_cours
  active
  annulee
}

enum TypePieceIdentite {
  cni
  passeport
  permis_conduire
}

model SouscriptionImf {
  id            String                @id @default(uuid())
  numeroPolice  String                @unique
  // agentId OU adminId : rattachée à un agent du réseau, ou souscrite
  // directement par un admin (indépendant de toute zone/agence/agent).
  agentId       String?
  agent         AgentImf?             @relation(fields: [agentId], references: [id])
  adminId       String?
  admin         Admin?                @relation("AdminSouscriptionsImf", fields: [adminId], references: [id])
  simulationId  String?               @unique
  simulation    SimulationImf?        @relation(fields: [simulationId], references: [id])
  produitCode   String
  nom           String
  prenom        String
  telephone     String
  email         String?
  typePiece     TypePieceIdentite?
  numeroPiece   String?
  ville           String?
  communeQuartier String?
  // Signature manuscrite du souscripteur (data URL PNG), facultative — capturée
  // au moment de la conversion simulation → souscription, cf. contract.ts.
  signature     String?
  entrees       Json
  resultat      Json
  primeTTC      Int
  statut        StatutSouscriptionImf @default(en_cours)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  sinistres     SinistreImf[]
  // Clé d'idempotence pour la synchronisation hors-ligne (PWA) — voir
  // SimulationImf.offlineId.
  offlineId     String?               @unique
}

// --- Phase 6 : sinistres IMF ---

enum StatutSinistreImf {
  declare
  pieces_attente
  complet
  instruction
  accepte
  rejete
  regle
}

model SinistreImf {
  id             String            @id @default(uuid())
  numeroSinistre String            @unique
  souscriptionId String
  souscription   SouscriptionImf   @relation(fields: [souscriptionId], references: [id])
  // Déclarant : un agent du réseau, ou l'admin (souscriptions directes).
  agentId        String?
  agent          AgentImf?         @relation(fields: [agentId], references: [id])
  adminId        String?
  admin          Admin?            @relation("AdminSinistresImf", fields: [adminId], references: [id])
  typeEvenement  String
  dateSurvenance DateTime
  dateDeclaration DateTime         @default(now())
  // Checklist des pièces requises pour ce produit/variante, figée au moment de
  // la déclaration : [{ label: string, fournie: boolean }]. Pas d'upload de
  // fichier dans l'appli (aucune infra en place) — l'agent coche après
  // vérification physique des pièces, cohérent avec la distribution en
  // présentiel de la branche IMF.
  pieces         Json
  montantEstime  Int?
  montantRegle   Int?
  // SECURSTOCK uniquement : l'indemnité est versée en priorité à l'IMF nantie
  // jusqu'à épuisement de l'encours du prêt, le solde revient au souscripteur.
  montantIMF            Int?
  montantSouscripteur   Int?
  motifRejet     String?
  statut         StatutSinistreImf @default(declare)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

// --- Phase 7 : bordereaux & règlement IMF ---
// Une AgenceImf correspond en pratique à l'agence d'une institution de
// microfinance (IMF) dans ce modèle de données — c'est donc l'unité pour
// laquelle un bordereau de production est émis.

enum StatutBordereauImf {
  emis
  partiellement_regle
  regle
}

model BordereauImf {
  id                String             @id @default(uuid())
  numero            String             @unique
  agenceId          String
  agence            AgenceImf          @relation(fields: [agenceId], references: [id])
  periodeDebut      DateTime
  periodeFin        DateTime
  // Souscriptions incluses, figées au moment de la génération (append-only :
  // un bordereau émis ne change pas rétroactivement si de nouvelles
  // souscriptions sont créées après coup dans la même période).
  souscriptionIds   Json
  nombreSouscriptions Int
  primeTotal        Int
  // Virements reçus en règlement, pointés au fil de l'eau (paiements
  // partiels possibles) : [{ montant, date, reference }]
  virements         Json               @default("[]")
  montantRecu       Int                @default(0)
  statut            StatutBordereauImf @default(emis)
  genereParAdminId  String?
  genereParAdmin    Admin?             @relation("AdminBordereauxImf", fields: [genereParAdminId], references: [id])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}
