# Copier en .env (jamais commité) et renseigner les valeurs réelles.
# Utilisé par docker-compose.yaml pour le déploiement (Dokploy ou autre hôte Docker).

# --- PostgreSQL ---
POSTGRES_USER=sim_assurances
POSTGRES_PASSWORD=change-moi
POSTGRES_DB=sim_assurances

# --- Backend ---
# Secret de signature des JWT (admin + partenaire) — chaîne aléatoire longue et unique en prod.
JWT_SECRET=change-moi

# URL publique de l'application (domaine Traefik), sans slash final.
# Utilisée pour construire les liens QR/SMS/WhatsApp et pour restreindre le CORS.
APP_PUBLIC_URL=https://protect.mysimassurances.com

# Compte Super Admin créé automatiquement au 1er démarrage s'il n'existe pas déjà.
SUPER_ADMIN_EMAIL=admin@simassurances.ci
SUPER_ADMIN_PASSWORD=change-moi
SUPER_ADMIN_NOM=Super Admin

# Paiement Wave — en l'absence de clé, le backend fonctionne en mode stub
# (confirmation immédiate sans appel réel à l'API Wave).
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=

# SMS (Sayele Send) — en l'absence de clé, les messages sont journalisés en console (mode stub).
SMS_API_KEY=
SMS_API_URL=
SMS_SENDER=

# NOVELIA (génération des cartes de prise en charge RelaxMoto/RelaxAuto) — en l'absence de
# clé, un numéro de carte local est généré (mode stub, API réelle pas encore intégrée).
NOVELIA_API_KEY=
